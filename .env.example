# dev-team 로컬 인프라 환경 변수 템플릿
#
# 사용:
#   cp .env.example .env
#   # 값을 원하는 대로 수정한 뒤
#   docker compose -f infra/docker-compose.yml --env-file .env up -d
#
# 실제 비밀 값(API 토큰 등)은 이 파일에 쓰지 않습니다.
# 본 템플릿은 git에 커밋되지만 `.env`는 `.gitignore`로 제외됩니다.

# ---- Neo4j ----
# Neo4j 기본 사용자는 항상 'neo4j'이며 변경 불가 (Community Edition).
# 비밀번호는 최소 8자 이상이어야 합니다.
NEO4J_USER=neo4j
NEO4J_PASSWORD=devteam_neo4j

# 호스트 노출 포트 (기본: 7474 HTTP / 7687 Bolt)
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ---- PostgreSQL ----
# 단일 인스턴스에 2개 DB 를 분리 운영:
#   POSTGRES_DB (`langgraph`) : langgraph-api 프레임워크 전용 (체크포인트/스레드/런)
#   APP_DB      (`dev_team`)  : 애플리케이션 document 저장 (PRD, Session/Task/Item, JSONB)
# 자세한 맥락은 docs/proposal.md, issue #20.
POSTGRES_USER=devteam
POSTGRES_PASSWORD=devteam_postgres

# 컨테이너 최초 부팅 시 POSTGRES_DB 자동 생성 → langgraph-api 가 사용.
POSTGRES_DB=langgraph
# 애플리케이션 DB (postgres-init 단계에서 추가 생성).
APP_DB=dev_team

# 호스트 노출 포트
POSTGRES_PORT=5432

# ---- Valkey ----
# Valkey는 Redis 호환 in-memory store (BSD 3-Clause). 기본적으로 인증 없이 로컬 바인딩만 (dev 용도).
VALKEY_PORT=6379

# ---- LLM Providers ----
# Anthropic API key (Primary 및 기타 LLM 호출 에이전트 공용).
# https://console.anthropic.com/settings/keys 에서 발급.
# 각 에이전트의 overrides/*.yaml 에서 `${ANTHROPIC_API_KEY}` 로 참조됨.
ANTHROPIC_API_KEY=
